{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openstaff.local/schemas/capture/context-snapshot.schema.json",
  "title": "ContextSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "appName",
    "appBundleId",
    "isFrontmost"
  ],
  "properties": {
    "appName": {
      "type": "string",
      "minLength": 1
    },
    "appBundleId": {
      "type": "string",
      "minLength": 1
    },
    "windowTitle": {
      "type": [
        "string",
        "null"
      ]
    },
    "windowId": {
      "type": [
        "string",
        "null"
      ]
    },
    "isFrontmost": {
      "type": "boolean"
    }
  }
}
